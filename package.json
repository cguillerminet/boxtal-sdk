{
  "name": "@l1l1/boxtal-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for Boxtal API v3",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc && tsc-alias",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "keywords": [
    "boxtal",
    "shipping",
    "typescript",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.18",
    "eslint": "^10.3.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.5"
  }
}
